<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} :: {% endif %}Léxico & Lentes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div id="container">

  <!-- HEADER -->
  <header id="header">
    <h1><a href="/" style="color:inherit;text-decoration:none;">Léxico & Lentes</a></h1>
    <p class="subtitle">Conhecimento técnico sem rastreadores, sem cookies, sem frescura.</p>
  </header>

  <!-- MAIN LAYOUT -->
  <div id="main">

    <!-- LEFT SIDEBAR: Parceiros Técnicos -->
    <aside id="leftbar">
      <h3>Parceiros Técnicos</h3>

      <a class="banner" href="https://www.vim.org" target="_blank" rel="noopener">
        <strong>[ VIM ]</strong>
        Editor supremo desde 1991
      </a>

      <a class="banner" href="https://www.rust-lang.org" target="_blank" rel="noopener">
        <strong>[ RUST ]</strong>
        Memória segura, zero GC
      </a>

      <a class="banner" href="https://www.11ty.dev" target="_blank" rel="noopener">
        <strong>[ 11ty ]</strong>
        Gerador estático simples
      </a>

      <a class="banner" href="https://archive.org" target="_blank" rel="noopener">
        <strong>[ IA ]</strong>
        Internet Archive
      </a>

      <a class="banner" href="https://github.com" target="_blank" rel="noopener">
        <strong>[ Git ]</strong>
        Social coding
      </a>

      <a class="banner" href="https://openbsd.org" target="_blank" rel="noopener">
        <strong>[ *BSD ]</strong>
        Free like freedom
      </a>

      <hr style="border:none;border-top:1px solid #ccc;margin:12px 0;">

      <p class="partner-footer">
        Quer aparecer aqui?<br>
        <a href="mailto:contato@exemplo.com">Mande um e-mail</a>
      </p>
    </aside>

    <!-- CENTER: Conteúdo -->
    <main id="content">
      {{ content | safe }}
    </main>

    <!-- RIGHT SIDEBAR: Arquivo & Tags -->
    <aside id="rightbar">

      <div class="section">
        <h3>Arquivo</h3>
        {% set postsByYear = collections.posts | groupByYear %}
        <ul class="archive-list">
        {% for year, yearPosts in postsByYear %}
          <li class="year">{{ year }}</li>
          {% for post in yearPosts | reverse %}
          <li>
            <a href="{{ post.url }}">{{ post.date | dateFormat }}</a>
          </li>
          {% endfor %}
        {% endfor %}
        </ul>
      </div>

      <div class="section">
        <h3>Tags</h3>
        <ul class="tag-list">
        {% for tag in collections.tagList %}
          <li><a href="/tags/{{ tag | slugify }}/">{{ tag }}</a></li>
        {% endfor %}
        </ul>
      </div>

      <div class="section">
        <h3>Sobre</h3>
        <p class="about-text">
          <a href="/sobre">
          Blog escrito em Markdown, compilado com Eleventy e hospedado no GitHub Pages.
          Layout inspirado na web dos anos 2000.
          </a>
        </p>
      </div>

      <div class="section">
        <h3>RSS</h3>
        <p class="rss-link">
          <a href="/feed.xml">📡 Feed RSS</a>
        </p>
      </div>

    </aside>

  </div>

  <!-- FOOTER -->
  <footer id="footer">
    <p>
      Blog Retro 2000 :: Feito com ❤️ e poucos bytes ::
      <a href="https://github.com">Código fonte</a>
    </p>
  </footer>

</div>

</body>
</html>
